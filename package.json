{
  "name": "databricks-axi",
  "version": "0.4.0",
  "packageManager": "pnpm@11.1.1",
  "description": "AXI-compliant Databricks CLI wrapper — token-efficient TOON output, contextual suggestions, idempotent mutations",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p33ves/databricks-axi.git"
  },
  "keywords": [
    "databricks",
    "cli",
    "agent",
    "axi",
    "toon",
    "spark",
    "unity-catalog"
  ],
  "bin": {
    "databricks-axi": "dist/bin/databricks-axi.js"
  },
  "files": [
    "dist",
    "skills/databricks-axi",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin/databricks-axi.js",
    "build:skill": "tsx scripts/build-skill.ts",
    "dev": "tsx bin/databricks-axi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axi-sdk-js": "^0.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  }
}
